{
  "name": "stoatx-monorepo",
  "version": "1.0.0",
  "description": "Moderation bot for Stoat and documentation fot the bot",
  "private": true,
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "version": "changeset version",
    "release": "pnpm -r build && changeset publish",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --build",
    "build": "pnpm -r build"
  },
  "keywords": [
    "stoat",
    "moderation",
    "bot",
    "documentation",
    "stoatbot"
  ],
  "homepage": "https://docs.stoatx.com",
  "author": "ispik <ispik@ispik.dev>",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@10.28.0",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}
