{
  "name": "stoatx",
  "version": "0.5.2",
  "description": "A high-performance, decorator-based command handler for the Stoat ecosystem.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stoatx-ts/stoatx.git"
  },
  "bugs": {
    "url": "https://github.com/stoatx-ts/stoatx/issues"
  },
  "homepage": "https://github.com/stoatx-ts/stoatx#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2",
    "@stoatx/client": "workspace:*",
    "tinyglobby": "^0.2.10"
  },
  "peerDependencies": {
    "reflect-metadata": "^0.2.0"
  }
}
